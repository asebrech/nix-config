# ML4W input configuration
# Keyboard and touchpad settings

{
  kb_layout = "us";
  numlock_by_default = true;
  follow_mouse = 1;
  mouse_refocus = false;

  touchpad = {
    natural_scroll = false;
    scroll_factor = 1.0;
    disable_while_typing = false;
  };

  sensitivity = 0; # -1.0 - 1.0, 0 means no modification
}
